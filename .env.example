# PolicySaathi Environment Configuration
# Copy this file to .env.local and fill in the values

# ===============================================
# OPENROUTER AI (Required)
# Get your API key from https://openrouter.ai
# ===============================================
OPENROUTER_API_KEY=sk-or-v1-...

# ===============================================
# SUPABASE DATABASE (Required)
# Create a project at https://supabase.com
# Run the SQL in supabase-setup.sql first
# ===============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ===============================================
# NEXTAUTH (Required for Google OAuth)
# Generate a secret: openssl rand -base64 32
# Optional: Set up Google OAuth in Google Cloud Console
# ===============================================
NEXTAUTH_SECRET=your-secret-key-here-change-this
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===============================================
# APPLICATION (Optional)
# ===============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===============================================
# DATA STORAGE PATHS (Optional - for advanced users)
# Default: ./data/ folder in project root
# Useful for production deployments with shared storage
# ===============================================
# USERS_FILE_PATH=./data/users.json
# IRDAI_DB_PATH=./data/irdai/entities_database.json
# HEADLINES_FILE_PATH=./data/irdai/headlines.json
# SCRAPER_SCRIPT_PATH=./scripts/daily_crawl.py

# ===============================================
# CHROMADB (Optional - RAG feature, not currently used)
# If you want to enable vector search for policies
# ===============================================
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
